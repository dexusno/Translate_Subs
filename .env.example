# Copy this file to .env and fill in the key(s) for your chosen provider.
#
#   cp .env.example .env
#
# .env is gitignored and will not be uploaded to GitHub.
# You only need the key for the profile you plan to use.

# DeepSeek  — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-key-here

# OpenAI    — https://platform.openai.com/api-keys
OPENAI_API_KEY=your-key-here

# Groq      — https://console.groq.com/keys
GROQ_API_KEY=your-key-here

# Mistral   — https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your-key-here

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=your-key-here

# Local (Ollama) — no key needed, just run: ollama serve
