{
  "default_profile": "deepseek",
  "remove_bitmap_subs": false,
  "target_language": {
    "name": "Norwegian",
    "codes": ["no", "nor", "nob", "nb", "nno"],
    "sidecar_code": "no",
    "mkv_tag": "nor",
    "keep_with": ["en", "eng", "da", "dan", "sv", "swe"]
  },
  "source_languages": [
    {"codes": ["en", "eng"], "name": "English"},
    {"codes": ["da", "dan"], "name": "Danish"},
    {"codes": ["sv", "swe"], "name": "Swedish"},
    {"codes": ["de", "deu", "ger"], "name": "German"},
    {"codes": ["nl", "nld", "dut"], "name": "Dutch"},
    {"codes": ["fr", "fra", "fre"], "name": "French"},
    {"codes": ["es", "spa"], "name": "Spanish"},
    {"codes": ["pt", "por"], "name": "Portuguese"},
    {"codes": ["it", "ita"], "name": "Italian"}
  ],
  "profiles": {
    "deepseek": {
      "api_url": "https://api.deepseek.com/v1/chat/completions",
      "model": "deepseek-chat",
      "api_key_env": "DEEPSEEK_API_KEY",
      "batch_size": 500,
      "parallel": 8
    },
    "openai": {
      "api_url": "https://api.openai.com/v1/chat/completions",
      "model": "gpt-4o",
      "api_key_env": "OPENAI_API_KEY",
      "batch_size": 500,
      "parallel": 8
    },
    "groq": {
      "api_url": "https://api.groq.com/openai/v1/chat/completions",
      "model": "llama-3.3-70b-versatile",
      "api_key_env": "GROQ_API_KEY",
      "batch_size": 500,
      "parallel": 8
    },
    "mistral": {
      "api_url": "https://api.mistral.ai/v1/chat/completions",
      "model": "mistral-large-latest",
      "api_key_env": "MISTRAL_API_KEY",
      "batch_size": 500,
      "parallel": 8
    },
    "openrouter": {
      "api_url": "https://openrouter.ai/api/v1/chat/completions",
      "model": "deepseek/deepseek-chat",
      "api_key_env": "OPENROUTER_API_KEY",
      "batch_size": 500,
      "parallel": 8
    },
    "local": {
      "api_url": "http://localhost:1234/v1/chat/completions",
      "model": "local",
      "api_key": "none",
      "timeout": 600,
      "batch_size": 25,
      "parallel": 1
    }
  }
}
